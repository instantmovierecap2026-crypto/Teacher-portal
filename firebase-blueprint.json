{
  "entities": {
    "Teacher": {
      "title": "Teacher",
      "description": "Represents a teacher in the school.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string", "description": "Unique ID entered manually" },
        "name": { "type": "string", "description": "Full Name" },
        "sex": { "type": "string", "enum": ["Male", "Female"] },
        "age": { "type": "number" },
        "role": { "type": "string", "enum": ["teacher", "admin"] },
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherId", "name", "createdAt"]
    },
    "Grade": {
      "title": "Grade",
      "description": "Represents a class section.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "e.g., Grade 10A" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "Represents a student profile.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "Unique student ID" },
        "name": { "type": "string" },
        "gradeId": { "type": "string", "description": "Reference to Grade ID" },
        "sex": { "type": "string", "enum": ["Male", "Female"] },
        "age": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "name", "gradeId", "createdAt"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Represents a subject module.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "passkey": { "type": "string" },
        "teacherId": { "type": "string", "description": "Reference to Teacher ID string (not UID)" },
        "gradeId": { "type": "string", "description": "Reference to Grade Doc ID" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "passkey", "teacherId", "gradeId", "createdAt"]
    },
    "Result": {
      "title": "Result",
      "description": "Represents student academic performance.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subjectId": { "type": "string" },
        "gradeId": { "type": "string" },
        "semester1": { "type": "string" },
        "semester2": { "type": "string" },
        "average": { "type": "string" },
        "rank": { "type": "string" },
        "status": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "subjectId", "gradeId", "updatedAt"]
    }
  },
  "firestore": {
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Teacher accounts."
    },
    "/grades/{gradeId}": {
      "schema": "Grade",
      "description": "Grade sections."
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student profiles."
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Subjects with passkeys."
    },
    "/results/{resultId}": {
      "schema": "Result",
      "description": "Academic records."
    }
  }
}
