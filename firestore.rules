rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read teachers (for login query)
    match /teachers/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow any authenticated user to read and write other documents
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
